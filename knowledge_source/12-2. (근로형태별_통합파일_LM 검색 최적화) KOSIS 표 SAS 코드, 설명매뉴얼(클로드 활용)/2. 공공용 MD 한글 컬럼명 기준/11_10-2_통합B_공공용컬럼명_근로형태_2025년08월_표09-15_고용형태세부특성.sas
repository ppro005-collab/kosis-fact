/* ══════════════════════════════════════════════════════════════════════════
   표09 — 한시적 근로자 규모 및 증감
   키워드: 한시적, 기간제, 비기간제, 계약반복, 단기근로, 규모, 증감, 구성비, 성별
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표9. 한시적_근로자_규모_및_증감                             */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS 검증 완료 | 모든 항목 차이 ±1천명 이내               */
/*==============================================================*/

/* ──────────────────────────────────────────────────────────── */
/* STEP 1. 데이터셋 준비                                        */
/* ──────────────────────────────────────────────────────────── */
data b2 b3 b4 b5;
    set ea_buga.ee1;

    /* 분석 기준: 8월 자료만 추출 */
    if substr(조사연월, 5, 2) = '08';

    /* 임금근로자 필터 (종사상지위 1=상용, 2=임시, 3=일용) */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;

    /* 불응 제외
       ※ 공공용 MDIS CSV는 불응자가 사전 제거되어 제공됩니다.
          내부망 원천 데이터 사용 시 아래 조건으로 대체하십시오:
          if 계약기간반복갱신여부 = 9 then delete;
          if 단기근로기간형태여부 = 9 then delete;      */

    /* ── 근로형태 플래그 생성 ──────────────────────────── */

    /* [기간제] 고용계약기간정함여부 = 1 */
    b4_flag = (현재일관련사항_고용계약기간정함여부 = 1);

    /* [비기간제-계약반복]
       조건: 고용계약기간정함여부=2 & 계속근로가능여부=1 & 계속근로가능사유코드=2
       ※ 계약기간반복갱신여부(항목58) 사용 금지
          비기간제 집단에서 계약기간반복갱신여부는 전부 0으로 수록됨 */
    b6_flag = (현재일관련사항_고용계약기간정함여부 = 2)
              and (계속근로가능여부 = 1)
              and (계속근로가능사유코드 = 2);

    /* [비기간제-단기근로]
       조건: 고용계약기간정함여부=2 & 계속근로가능여부=2 & 근속기간제한사유코드 in 1~6 */
    b7_flag = (현재일관련사항_고용계약기간정함여부 = 2)
              and (계속근로가능여부 = 2)
              and (1 <= 근속기간제한사유코드 <= 6);

    /* [비기간제] = 계약반복 OR 단기근로 */
    b5_flag = b6_flag or b7_flag;

    /* [한시적] = 기간제 OR 비기간제 */
    b3_flag = b4_flag or b5_flag;

    /* [비정규직] = 한시적 OR 시간제 OR 비전형 (OR 연산, 중복 제거) */
    b8_flag  = (근로시간형태코드 = 2);                      /* 시간제 */
    b9_flag  = (급여수령위치코드 = 2) or (급여수령위치코드 = 3)  /* 파견·용역 */
            or (특수형태근로종사자여부 = 1)                 /* 특고 */
            or (근로장소코드 = 1)                           /* 가정내 */
            or (단기근로기간형태여부 = 1);                  /* 일일 */
    b2_flag  = b3_flag or b8_flag or b9_flag;

    /* 가중치 (천 명 단위) */
    wei = 가중값 / 1000;

    /* 분류별 파일 출력 */
    if b2_flag then output b2;
    if b3_flag then output b3;
    if b4_flag then output b4;
    if b5_flag then output b5;
run;


/* ──────────────────────────────────────────────────────────── */
/* STEP 2. 성별 집계 매크로                                     */
/* ──────────────────────────────────────────────────────────── */
%macro buga(i=, o=, s=);
    proc means data=&i sum noprint;
        var wei;
        class 조사연월 성별코드;
        output out=&o sum=&s;
    run;
    data &o;
        set &o;
        if 조사연월 ^= '';
        keep 조사연월 성별코드 &s;
    run;
    proc sort data=&o; by 조사연월 성별코드; run;
%mend buga;

%buga(i=b2, o=o2, s=s2);   /* 비정규직 */
%buga(i=b3, o=o3, s=s3);   /* 한시적   */
%buga(i=b4, o=o4, s=s4);   /* 기간제   */
%buga(i=b5, o=o5, s=s5);   /* 비기간제 */


/* ──────────────────────────────────────────────────────────── */
/* STEP 3. 결과 병합 및 정리 (근로자수 + 구성비 + 증감 + 증감률)*/
/* ──────────────────────────────────────────────────────────── */

/* 3-1. 당해 연도 근로자수 */
data result_num;
    merge o2 o3 o4 o5;
    by 조사연월 성별코드;

    format 연월 $char6.;   연월 = 조사연월;
    format 성별 $char6.;
    if 성별코드 = 1 then 성별 = '1남자';
    else if 성별코드 = 2 then 성별 = '2여자';
    else 성별 = '0합계';

    /* 반올림 */
    s2 = round(s2, 0.1);  s3 = round(s3, 0.1);
    s4 = round(s4, 0.1);  s5 = round(s5, 0.1);

    비정규직 = s2;  한시적 = s3;  기간제 = s4;  비기간제 = s5;

    drop s2 s3 s4 s5 조사연월 성별코드;
run;

/* 3-2. 구성비 (비정규직대비, %) */
data result_pct;
    set result_num;
    format 구분 $12.;  구분 = '구성비(%)';
    if 비정규직 > 0 then do;
        한시적   = round(한시적   / 비정규직 * 100, 0.1);
        기간제   = round(기간제   / 비정규직 * 100, 0.1);
        비기간제 = round(비기간제 / 비정규직 * 100, 0.1);
        비정규직 = 100.0;
    end;
run;

/* 3-3. 증감 = 당해 연도 - 전년동월
   ※ 전년동월 데이터셋(prev_num)을 동일 방법으로 별도 집계 후 사용 */
/*
data result_diff;
    merge result_num(rename=(비정규직=c2 한시적=c3 기간제=c4 비기간제=c5))
          prev_num  (rename=(비정규직=p2 한시적=p3 기간제=p4 비기간제=p5));
    by 성별;
    비정규직 = round(c2 - p2, 0.1);
    한시적   = round(c3 - p3, 0.1);
    기간제   = round(c4 - p4, 0.1);
    비기간제 = round(c5 - p5, 0.1);
run;
*/


/* ──────────────────────────────────────────────────────────── */
/* STEP 4. 엑셀 출력                                            */
/* ──────────────────────────────────────────────────────────── */
proc export data=result_num
    outfile="I:\집계\근로형태별\근로형태 집계25.xlsx"
    dbms=xlsx replace;
    sheet='한시적규모';
run;

proc export data=result_pct
    outfile="I:\집계\근로형태별\근로형태 집계25.xlsx"
    dbms=xlsx replace;
    sheet='한시적구성비';
run;

/* ──────────────────────────────────────────────────────────── */


/* ══════════════════════════════════════════════════════════════════════════
   표10 — 시간제 근로자 고용안정성 비율
   키워드: 시간제, 고용안정성, 계속근로가능, 비율, 분모, 분자
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표10. 시간제근로자_고용안정성_비율                          */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS 검증 완료 | MDIS 56.4% = KOSIS 56.4% (완전 일치)   */
/*==============================================================*/

/*──────────────────────────────────────────────────────────────*/
/* STEP 1. 시간제 근로자 데이터셋 준비 (b8)                    */
/*──────────────────────────────────────────────────────────────*/
data b8;
    set ea_buga.ee1;

    /* 분석 기준: 8월 자료만 추출 */
    if substr(조사연월, 5, 2) = '08';

    /* 임금근로자 필터 (종사상지위 1=상용, 2=임시, 3=일용) */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;

    /* 불응 제외 (공공용 파일은 사전 제거 — 필요 시 적용) */

    /* [시간제] 근로시간형태코드 = 2 */
    if 근로시간형태코드 ^= 2 then delete;   /* 시간제만 유지 */

    /* 가중치 (천 명 단위) */
    wei = 가중값 / 1000;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 2. 고용안정성 비율 집계                                 */
/*                                                              */
/*  고용안정성 비율 =                                           */
/*    시간제 중 계속근로가능(계속근로가능여부=1) 인원            */
/*    ─────────────────────────────────────────── × 100        */
/*               시간제 전체 인원                               */
/*                                                              */
/*  ※ 분모: 시간제 전체 (계속근로가능여부 코드 무관)           */
/*  ※ 분자: 계속근로가능여부 = 1 인 시간제 근로자             */
/*──────────────────────────────────────────────────────────────*/
%macro buga(i=, o=, s=, ss=, p=);
    /* 계속근로가능여부별 · 연월별 시간제 합계 */
    proc means data=&i sum noprint;
        var wei;
        class 조사연월 계속근로가능여부;
        output out=temp_o sum=&s;
    run;

    data temp_o;
        set temp_o;
        if 조사연월 ^= '';
        keep 조사연월 계속근로가능여부 &s;
    run;

    /* 분모: 전체 합계 (계속근로가능여부 = 결측 = 소계 행) */
    data temp_o2;
        set temp_o;
        if 계속근로가능여부 = .;
        &ss = &s;
        drop &s 계속근로가능여부;
    run;

    /* 비율 산출 */
    data &o;
        merge temp_o temp_o2;
        by 조사연월;
        &p = &s / &ss * 100;
        &p = round(&p, 0.1);
        drop &s &ss;
        if 계속근로가능여부 = 1;   /* 계속근로가능(=1)인 행만 유지 */
    run;
%mend buga;

%buga(i=b8, o=o8, s=s8, ss=ss8, p=p8);


/*──────────────────────────────────────────────────────────────*/
/* STEP 3. 결과 정리                                            */
/*──────────────────────────────────────────────────────────────*/
data result;
    set o8;

    format 연월 $char6.;
    연월 = 조사연월;

    /* 고용안정성 비율 (%) */
    고용안정성비율 = p8;

    drop 조사연월 p8;
run;

proc sort data=result; by 연월; run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 4. 엑셀 출력                                            */
/*──────────────────────────────────────────────────────────────*/
proc export data=result
    outfile="I:\집계\근로형태별\근로형태 집계25.xlsx"
    dbms=xlsx replace;
    sheet='시간제고용안정성';
run;

/* ──────────────────────────────────────────────────────────── */


/* ══════════════════════════════════════════════════════════════════════════
   표11 — 성별 시간제 근로자 주당 평균취업시간
   키워드: 시간제, 성별, 주당평균취업시간, 취업시간, 남자, 여자, 가중평균, 일시휴직자
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표11. 성별_시간제근로자_주당_평균취업시간                   */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS: 계=18.1시간 / 남=18.9시간 / 여=17.8시간            */
/*==============================================================*/

/*──────────────────────────────────────────────────────────────*/
/* STEP 1. 시간제 근로자 데이터셋 준비 (b8)                    */
/*──────────────────────────────────────────────────────────────*/
data b8;
    set ea_buga.ee1;

    /* 분석 기준: 8월 자료만 추출 */
    if substr(조사연월, 5, 2) = '08';

    /* 임금근로자 필터 (종사상지위 1=상용, 2=임시, 3=일용) */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;

    /* 불응 제외 (공공용 파일은 사전 제거 — 필요 시 적용) */

    /* [시간제] 근로시간형태코드 = 2 */
    if 근로시간형태코드 ^= 2 then delete;

    /* 가중치 (천 명 단위) */
    wei = 가중값 / 1000;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 2. 성별 주당 평균취업시간 집계                          */
/*                                                              */
/*  사용 변수: 현재일관련사항_총실제취업시간수 (주업 + 부업)    */
/*  집계 방식: 가중평균 (weight=wei)                            */
/*  반올림:   round(, 0.1) → 소수점 첫째 자리                 */
/*                                                              */
/*  ※ 일시휴직자(총실제취업시간수=0)는 제외하지 않고 포함      */
/*    → 0 제외 시 KOSIS 값보다 약 1시간 높게 산출됨            */
/*──────────────────────────────────────────────────────────────*/
%macro buga(i=, o=, s=);
    proc means data=&i mean noprint;
        var 현재일관련사항_총실제취업시간수;   /* 총실제취업시간수(주업+부업) */
        class 조사연월 성별코드;
        weight wei;
        output out=&o mean=&s;
    run;

