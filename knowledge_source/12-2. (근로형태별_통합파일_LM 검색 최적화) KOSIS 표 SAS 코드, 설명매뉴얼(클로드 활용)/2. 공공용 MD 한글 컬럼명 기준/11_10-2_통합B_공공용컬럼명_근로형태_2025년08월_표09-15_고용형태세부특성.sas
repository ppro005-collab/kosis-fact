/* ══════════════════════════════════════════════════════════════════════════
   표14 — 일자리선택동기별 근로형태별 구성비
   키워드: 일자리선택동기, 자발적, 비자발적, 근로조건만족, 안정적일자리, 이중분모
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표14. 일자리선택동기별_근로형태별_구성비                    */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS 검증 완료 | 7개 근로형태 × 10개 항목 전부 완전 일치  */
/*==============================================================*/

/*──────────────────────────────────────────────────────────────*/
/* STEP 1. 근로형태별 데이터셋 준비                             */
/*──────────────────────────────────────────────────────────────*/
data b1 b2 b3 b4 b5 b8 b9;
    set ea_buga.ee1;

    if substr(조사연월,5,2) = '08';                                /* 8월만 */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;  /* 임금근로자 */
    /* 불응 제외 (공공용 파일은 사전 제거 — 필요 시 적용) */

    /* ── 근로형태 플래그 ─────────────────────────────── */
    b4_f  = (현재일관련사항_고용계약기간정함여부=1);
    b6_f  = (현재일관련사항_고용계약기간정함여부=2) and (계속근로가능여부=1) and (계속근로가능사유코드=2);
    b7_f  = (현재일관련사항_고용계약기간정함여부=2) and (계속근로가능여부=2) and (1<=근속기간제한사유코드<=6);
    b5_f  = b6_f or b7_f;
    b3_f  = b4_f or b5_f;
    b8_f  = (근로시간형태코드=2);
    b10_f = (급여수령위치코드=2);
    b11_f = (급여수령위치코드=3);
    b12_f = (특수형태근로종사자여부=1);
    b13_f = (근로장소코드=1);
    b14_f = (단기근로기간형태여부=1);
    b9_f  = b10_f or b11_f or b12_f or b13_f or b14_f;
    b2_f  = b3_f or b8_f or b9_f;
    b1_f  = ^b2_f;

    wei = 가중값 / 1000;

    if b1_f  then output b1;   /* 정규직   */
    if b2_f  then output b2;   /* 비정규직 */
    if b3_f  then output b3;   /* 한시적   */
    if b4_f  then output b4;   /* 기간제   */
    if b5_f  then output b5;   /* 비기간제 */
    if b8_f  then output b8;   /* 시간제   */
    if b9_f  then output b9;   /* 비전형   */
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 2. 일자리선택동기별 구성비 집계 매크로                  */
/*                                                              */
/*  사용 변수:                                                  */
/*  지난주취업동기코드       1=자발적 / 2=비자발적              */
/*  지난주취업_주요사유코드  세부 동기 1~11                     */
/*                                                              */
/*  구성비 분모 (이중 분모 구조):                               */
/*  - 자발/비자발 비중:  해당 근로형태 전체                     */
/*  - 세부 항목 비중:    자발(또는 비자발) 소계                 */
/*──────────────────────────────────────────────────────────────*/
%macro buga(i=, o=, s=, ss=, p=);

    /* ── 자발적(지난주취업동기코드=1) 동기 재분류 ────────── */
    data bb_z;
        set &i;
        if 지난주취업동기코드=1;  /* 자발적만 */
        if      지난주취업_주요사유코드=1              then code=1;  /* 근로조건에 만족  */
        else if 지난주취업_주요사유코드=2              then code=2;  /* 안정적인 일자리  */
        else if 지난주취업_주요사유코드 in(6,7,8)      then code=3;  /* 직장이동 등      */
        else if 지난주취업_주요사유코드 in(9,10,11)    then code=4;  /* 노력한만큼 수입  */
        if code = .  then delete;
    run;

    /* ── 비자발적(지난주취업동기코드=2) 동기 재분류 ───────── */
    data bb_b;
        set &i;
        if 지난주취업동기코드=2;  /* 비자발적만 */
        if      지난주취업_주요사유코드=3              then code=5;  /* 당장 수입이 필요        */
        else if 지난주취업_주요사유코드 in(4,5)        then code=6;  /* 원하는 일자리 없음 등   */
        else if 지난주취업_주요사유코드 in(6,7,8)      then code=3;  /* 직장이동 등 (공통)      */
        else if 지난주취업_주요사유코드 in(9,10,11)    then code=4;  /* 노력한만큼 수입 (공통)  */
        if code = .  then delete;
    run;

    /* ── 자발/비자발 집계 (소계용) ─────────────────────── */
    proc means data=&i sum noprint;
        var wei;
        class 조사연월 지난주취업동기코드;
        output out=temp_total sum=&s;
    run;
    data temp_total;
        set temp_total;
        if 조사연월 ^= '' and 지난주취업동기코드 ^= .;
        keep 조사연월 지난주취업동기코드 &s;
    run;

    /* ── 전체 합계 (전체 분모용) ─────────────────────── */
    proc means data=&i sum noprint;
        var wei;
        class 조사연월;
        output out=temp_all sum=&ss;
    run;
    data temp_all;
        set temp_all;
        if 조사연월 ^= '' and _TYPE_=1;
        keep 조사연월 &ss;
    run;

    /* ── 자발 세부 집계 ──────────────────────────────── */
    proc means data=bb_z sum noprint;
        var wei;
        class 조사연월 code;
        output out=temp_z sum=&s;
    run;
    data temp_z;
        set temp_z;
        if 조사연월 ^= '' and code ^= .;
        지난주취업동기코드 = 1;
        keep 조사연월 지난주취업동기코드 code &s;
    run;

    /* ── 비자발 세부 집계 ────────────────────────────── */
    proc means data=bb_b sum noprint;
        var wei;
        class 조사연월 code;
        output out=temp_b sum=&s;
    run;
    data temp_b;
        set temp_b;
        if 조사연월 ^= '' and code ^= .;
        지난주취업동기코드 = 2;
        keep 조사연월 지난주취업동기코드 code &s;
    run;

    /* ── 구성비 계산 ──────────────────────────────────── */
    /* 자발/비자발 비중: 전체 대비 */
    data zb_pct;
        merge temp_total temp_all;
        by 조사연월;
        &p = round(&s / &ss * 100, 0.1);
        drop &ss;
    run;

    /* 자발 세부: 자발 소계 대비 */
    data z_sub;
        merge temp_z(rename=(&s=&s._sub))
              temp_total(where=(지난주취업동기코드=1) rename=(&s=&ss._z));
        by 조사연월 지난주취업동기코드;
        &p = round(&s._sub / &ss._z * 100, 0.1);
        drop &s._sub &ss._z;
    run;

    /* 비자발 세부: 비자발 소계 대비 */
    data b_sub;
        merge temp_b(rename=(&s=&s._sub))
              temp_total(where=(지난주취업동기코드=2) rename=(&s=&ss._b));
        by 조사연월 지난주취업동기코드;
        &p = round(&s._sub / &ss._b * 100, 0.1);
        drop &s._sub &ss._b;
    run;

    data &o;
        set zb_pct z_sub b_sub;
    run;
    proc sort data=&o; by 조사연월 지난주취업동기코드 code; run;
%mend buga;

%buga(i=b1, o=o1, s=s1, ss=ss1, p=p1);
%buga(i=b2, o=o2, s=s2, ss=ss2, p=p2);
%buga(i=b3, o=o3, s=s3, ss=ss3, p=p3);
%buga(i=b4, o=o4, s=s4, ss=ss4, p=p4);
%buga(i=b5, o=o5, s=s5, ss=ss5, p=p5);
%buga(i=b8, o=o8, s=s8, ss=ss8, p=p8);
%buga(i=b9, o=o9, s=s9, ss=ss9, p=p9);


/*──────────────────────────────────────────────────────────────*/
/* STEP 3. 결과 정리                                            */
/*──────────────────────────────────────────────────────────────*/
data result;
    merge o1(rename=(p1=정규직))
          o2(rename=(p2=비정규직))
          o3(rename=(p3=한시적))
          o4(rename=(p4=기간제))
          o5(rename=(p5=비기간제))
          o8(rename=(p8=시간제))
          o9(rename=(p9=비전형));
    by 조사연월 지난주취업동기코드 code;

    format 연월 $char6.;  연월 = 조사연월;

    format 자발여부 $20.;
    if      지난주취업동기코드=1 then 자발여부='1.자발적사유';
    else if 지난주취업동기코드=2 then 자발여부='2.비자발적사유';
    else                              자발여부='0.합계';

    format 동기 $30.;
    if      code=1 then 동기='1.근로조건에만족';
    else if code=2 then 동기='2.안정적인일자리';
    else if code=3 then 동기='3.직장이동등';
    else if code=4 then 동기='4.노력한만큼수입등';
    else if code=5 then 동기='5.당장수입이필요';
    else if code=6 then 동기='6.원하는일자리없음등';
    else if code=. then 동기='0.소계';

    drop 조사연월 지난주취업동기코드 code;
run;

proc sort data=result; by 연월 자발여부 동기; run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 4. 엑셀 출력                                            */
/*──────────────────────────────────────────────────────────────*/
proc export data=result
    outfile="I:\집계\근로형태별\근로형태 집계25.xlsx"
    dbms=xlsx replace;
    sheet='일자리선택동기';
run;

/* ──────────────────────────────────────────────────────────── */


/* ══════════════════════════════════════════════════════════════════════════
   표15 — 근로형태별 평균근속기간 및 근속기간별 구성비
   키워드: 평균근속기간, 근속기간, 1년미만, 1~3년미만, 3년이상, 구성비, 직장시작연월
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표15. 근로형태별_평균근속기간_및_근속기간별_구성비          */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS 검증 완료 | 8개 근로형태 × 4개 항목 전부 완전 일치   */
/*==============================================================*/

/*──────────────────────────────────────────────────────────────*/
/* STEP 1. 근속기간 변수 생성 및 근로형태별 데이터셋 준비       */
/*──────────────────────────────────────────────────────────────*/
data b0 b1 b2 b3 b4 b5 b8 b9;
    set ea_buga.ee1;

    if substr(조사연월,5,2) = '08';                                /* 8월만    */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;  /* 임금근로자 */
    /* 불응 제외 (공공용 파일은 사전 제거 — 필요 시 적용) */

    /* ── 근속기간 계산 (월 단위) ─────────────────────── */
    /*  현재일관련사항_직장시작연월 = 현재 직장 입사연월 (YYYYMM) */
    /*  근속기간 = (조사연도-시작연도)*12 + (조사월-시작월)       */
    survey_y = input(substr(조사연월,1,4), 4.);
    survey_m = input(substr(조사연월,5,2), 2.);
    start_y  = int(현재일관련사항_직장시작연월 / 100);
    start_m  = mod(현재일관련사항_직장시작연월, 100);
    tenure   = (survey_y - start_y)*12 + (survey_m - start_m);

    /* ── 근로형태 플래그 ─────────────────────────────── */
    b4_f  = (현재일관련사항_고용계약기간정함여부=1);
    b6_f  = (현재일관련사항_고용계약기간정함여부=2) and (계속근로가능여부=1) and (계속근로가능사유코드=2);
    b7_f  = (현재일관련사항_고용계약기간정함여부=2) and (계속근로가능여부=2) and (1<=근속기간제한사유코드<=6);
    b5_f  = b6_f or b7_f;
    b3_f  = b4_f or b5_f;
    b8_f  = (근로시간형태코드=2);
    b10_f = (급여수령위치코드=2);
    b11_f = (급여수령위치코드=3);
    b12_f = (특수형태근로종사자여부=1);
    b13_f = (근로장소코드=1);
    b14_f = (단기근로기간형태여부=1);
    b9_f  = b10_f or b11_f or b12_f or b13_f or b14_f;
    b2_f  = b3_f or b8_f or b9_f;
    b1_f  = ^b2_f;

    wei = 가중값 / 1000;

    output b0;                    /* 임금근로자 (전체) */
    if b1_f  then output b1;      /* 정규직   */
    if b2_f  then output b2;      /* 비정규직 */
    if b3_f  then output b3;      /* 한시적   */
    if b4_f  then output b4;      /* 기간제   */
    if b5_f  then output b5;      /* 비기간제 */
    if b8_f  then output b8;      /* 시간제   */
    if b9_f  then output b9;      /* 비전형   */
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 2-A. 평균근속기간 집계 매크로 (가중평균, 개월 단위)     */
/*──────────────────────────────────────────────────────────────*/
%macro mean_tenure(i=, o=, s=);
    proc means data=&i mean noprint;
        var tenure;
        class 조사연월;
        weight wei;
        output out=&o mean=&s;
    run;
    data &o;
        set &o;
        if 조사연월 ^= '' and _TYPE_=1;
        &s = round(&s);          /* 반올림 → 정수 (개월) */
        keep 조사연월 &s;
    run;
%mend mean_tenure;

%mean_tenure(i=b0, o=m0, s=s0);
%mean_tenure(i=b1, o=m1, s=s1);
%mean_tenure(i=b2, o=m2, s=s2);
%mean_tenure(i=b3, o=m3, s=s3);
%mean_tenure(i=b4, o=m4, s=s4);
%mean_tenure(i=b5, o=m5, s=s5);
%mean_tenure(i=b8, o=m8, s=s8);
%mean_tenure(i=b9, o=m9, s=s9);


/*──────────────────────────────────────────────────────────────*/
/* STEP 2-B. 근속기간별 구성비 집계 매크로                      */
/*                                                              */
/*  구간 정의:                                                  */
/*  - 1년 미만:    tenure < 12                                  */
/*  - 1~3년 미만:  12 <= tenure < 36                           */
/*  - 3년 이상:    tenure >= 36                                 */
/*──────────────────────────────────────────────────────────────*/
%macro pct_tenure(i=, o=, s=, ss=, p=);
    /* 구간 변수 생성 */
    data temp_i;
        set &i;
        if      tenure <  12 then gunsok=1;   /* 1년 미만    */
        else if tenure <  36 then gunsok=2;   /* 1~3년 미만  */
        else                      gunsok=3;   /* 3년 이상    */
    run;

    /* 구간별 가중합 */
    proc means data=temp_i sum noprint;
        var wei;
        class 조사연월 gunsok;
        output out=temp_o sum=&s;
    run;
    data temp_o;
        set temp_o;
        if 조사연월 ^= '' and gunsok ^= .;
        keep 조사연월 gunsok &s;
    run;

    /* 전체 합계 (분모) */
    proc means data=&i sum noprint;
        var wei;
        class 조사연월;
        output out=temp_all sum=&ss;
    run;
    data temp_all;
        set temp_all;
        if 조사연월 ^= '' and _TYPE_=1;
        keep 조사연월 &ss;
    run;

    /* 구성비 계산 */
    data &o;
        merge temp_o temp_all;
        by 조사연월;
        &p = round(&s / &ss * 100, 0.1);
        keep 조사연월 gunsok &p;
    run;
    proc sort data=&o; by 조사연월 gunsok; run;
%mend pct_tenure;

%pct_tenure(i=b0, o=p0, s=s0, ss=ss0, p=pct0);
%pct_tenure(i=b1, o=p1, s=s1, ss=ss1, p=pct1);
%pct_tenure(i=b2, o=p2, s=s2, ss=ss2, p=pct2);
%pct_tenure(i=b3, o=p3, s=s3, ss=ss3, p=pct3);
%pct_tenure(i=b4, o=p4, s=s4, ss=ss4, p=pct4);
%pct_tenure(i=b5, o=p5, s=s5, ss=ss5, p=pct5);
%pct_tenure(i=b8, o=p8, s=s8, ss=ss8, p=pct8);
%pct_tenure(i=b9, o=p9, s=s9, ss=ss9, p=pct9);


/*──────────────────────────────────────────────────────────────*/
/* STEP 3. 결과 정리 — 평균근속기간                             */
/*──────────────────────────────────────────────────────────────*/
data result_mean;
    merge m0(rename=(s0=임금근로자))
          m1(rename=(s1=정규직))
          m2(rename=(s2=비정규직))
          m3(rename=(s3=한시적))
          m4(rename=(s4=기간제))
          m5(rename=(s5=비기간제))
          m8(rename=(s8=시간제))
          m9(rename=(s9=비전형));
    by 조사연월;

    format 연월 $char6.;  연월 = 조사연월;
    항목 = '평균근속기간(개월)';
    drop 조사연월;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 4. 결과 정리 — 근속기간별 구성비                        */
/*──────────────────────────────────────────────────────────────*/
data result_pct;
    merge p0(rename=(pct0=임금근로자))
          p1(rename=(pct1=정규직))
          p2(rename=(pct2=비정규직))
          p3(rename=(pct3=한시적))
          p4(rename=(pct4=기간제))
          p5(rename=(pct5=비기간제))
          p8(rename=(pct8=시간제))
          p9(rename=(pct9=비전형));
    by 조사연월 gunsok;

    format 연월 $char6.;  연월 = 조사연월;
    format 항목 $15.;
    if      gunsok=1 then 항목='1년미만';
    else if gunsok=2 then 항목='1~3년미만';
    else if gunsok=3 then 항목='3년이상';
    drop 조사연월 gunsok;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 5. 엑셀 출력                                            */
/*──────────────────────────────────────────────────────────────*/
proc export data=result_mean
    outfile="I:\집계\근로형태별\근로형태 집계25.xlsx"
    dbms=xlsx replace;
    sheet='평균근속기간';
run;

proc export data=result_pct
    outfile="I:\집계\근로형태별\근로형태 집계25.xlsx"
    dbms=xlsx replace;
    sheet='근속기간별구성비';
run;

/*
================================================================================
  END — B. 고용형태 세부 특성 (공공용 컬럼명 교정 버전)
  포함 표: 표09~15 | 조사: 2025년 8월 경제활동인구조사 근로형태별 부가조사
================================================================================
*/
