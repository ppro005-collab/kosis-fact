   키워드: 시간제, 성별, 월평균임금, 3개월간평균급여, 만원, 가중평균
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표12. 성별_시간제근로자_최근_3개월간_월평균임금             */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS: 계=111.5만원 / 남=119.8만원 / 여=108.2만원          */
/*==============================================================*/

/*──────────────────────────────────────────────────────────────*/
/* STEP 1. 시간제 근로자 데이터셋 준비 (b8)                    */
/*──────────────────────────────────────────────────────────────*/
data b8;
    set ea_buga.ee1;

    /* 분석 기준: 8월 자료만 추출 */
    if substr(조사연월, 5, 2) = '08';

    /* 임금근로자 필터 (종사상지위 1=상용, 2=임시, 3=일용) */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;

    /* 불응 제외 (공공용 파일은 사전 제거 — 필요 시 적용) */

    /* [시간제] 근로시간형태코드 = 2 */
    if 근로시간형태코드 ^= 2 then delete;

    /* 가중치 (천 명 단위) */
    wei = 가중값 / 1000;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 2. 성별 월평균임금 집계 (가중평균)                      */
/*                                                              */
/*  사용 변수: 최근3개월간평균급여 (단위: 만원)                */
/*  집계 방식: 가중평균 (weight=wei)                            */
/*  반올림:   round(, 0.1) → 소수점 첫째 자리                 */
/*                                                              */
/*  ※ 임금=0인 표본은 MDIS에 존재하지 않으므로 별도 필터 불필요*/
/*  ※ 중위수(median)가 아닌 가중평균(mean)을 사용              */
/*──────────────────────────────────────────────────────────────*/
%macro buga(i=, o=, s=);
    proc means data=&i mean noprint;
        var 최근3개월간평균급여;   /* 최근 3개월간 평균급여 (만원) */
        class 조사연월 성별코드;
        weight wei;
        output out=&o mean=&s;
    run;

    data &o;
        set &o;
        if 조사연월 ^= '';
        &s = round(&s, 0.1);
        keep 조사연월 성별코드 &s;
    run;

    proc sort data=&o; by 조사연월 성별코드; run;
%mend buga;

%buga(i=b8, o=o8, s=s8);


/*──────────────────────────────────────────────────────────────*/
/* STEP 3. 결과 정리                                            */
/*──────────────────────────────────────────────────────────────*/
data result;
    set o8;

    format 연월 $char6.;
    연월 = 조사연월;

    format 성별 $char6.;
    if      성별코드 = 1 then 성별 = '1남자';
    else if 성별코드 = 2 then 성별 = '2여자';
    else                      성별 = '0합계';

    월평균임금_만원 = s8;

    drop 조사연월 성별코드 s8;
run;

proc sort data=result; by 연월 성별; run;


