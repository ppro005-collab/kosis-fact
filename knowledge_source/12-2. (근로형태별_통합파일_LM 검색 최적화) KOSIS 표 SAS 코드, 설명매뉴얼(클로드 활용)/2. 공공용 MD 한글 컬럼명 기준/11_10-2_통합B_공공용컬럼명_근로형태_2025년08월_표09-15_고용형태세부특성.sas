   표13 — 비전형 근로자 규모 및 증감
   키워드: 비전형, 파견, 용역, 특수형태, 특고, 가정내, 일일근로, 규모, 증감, 구성비
   ══════════════════════════════════════════════════════════════════════════ */

/*==============================================================*/
/*  표13. 비전형_근로자_규모_및_증감                            */
/*  기준: 2025년 8월 경제활동인구조사 근로형태별 부가조사       */
/*  KOSIS 검증 완료 | 근로자수·구성비·증감률 모두 ±1 이내      */
/*==============================================================*/

/*──────────────────────────────────────────────────────────────*/
/* STEP 1. 비전형 유형별 데이터셋 준비                         */
/*──────────────────────────────────────────────────────────────*/
data b2 b9 b10 b11 b12 b13 b14;
    set ea_buga.ee1;

    if substr(조사연월, 5, 2) = '08';                              /* 8월만 */
    if not (1 <= 현재일관련사항_종사상지위코드 <= 3) then delete;  /* 임금근로자 */
    /* 불응 제외 (공공용 파일은 사전 제거 — 필요 시 적용) */

    /* ── 근로형태 플래그 ─────────────────────────────── */
    /* 한시적 */
    b4_f  = (현재일관련사항_고용계약기간정함여부 = 1);
    b6_f  = (현재일관련사항_고용계약기간정함여부=2) and (계속근로가능여부=1) and (계속근로가능사유코드=2);
    b7_f  = (현재일관련사항_고용계약기간정함여부=2) and (계속근로가능여부=2) and (1<=근속기간제한사유코드<=6);
    b5_f  = b6_f or b7_f;
    b3_f  = b4_f or b5_f;
    b8_f  = (근로시간형태코드 = 2);              /* 시간제 */

    /* 비전형 5유형 */
    b10_f = (급여수령위치코드 = 2);              /* 파견     */
    b11_f = (급여수령위치코드 = 3);              /* 용역     */
    b12_f = (특수형태근로종사자여부 = 1);        /* 특수형태 */
    b13_f = (근로장소코드 = 1);                  /* 가정내   */
    b14_f = (단기근로기간형태여부 = 1);          /* 일일근로 */
    b9_f  = b10_f or b11_f or b12_f or b13_f or b14_f;

    /* 비정규직 (OR 연산 → 중복 제거) */
    b2_f  = b3_f or b8_f or b9_f;

    wei = 가중값 / 1000;   /* 천 명 단위 */

    if b2_f  then output b2;
    if b9_f  then output b9;
    if b10_f then output b10;
    if b11_f then output b11;
    if b12_f then output b12;
    if b13_f then output b13;
    if b14_f then output b14;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 2. 성별 집계 매크로                                     */
/*──────────────────────────────────────────────────────────────*/
%macro buga(i=, o=, s=);
    proc means data=&i sum noprint;
        var wei;
        class 조사연월 성별코드;
        output out=&o sum=&s;
    run;
    data &o;
        set &o;
        if 조사연월 ^= '';
        keep 조사연월 성별코드 &s;
    run;
    proc sort data=&o; by 조사연월 성별코드; run;
%mend buga;

%buga(i=b2,  o=o2,  s=s2);   /* 비정규직 */
%buga(i=b9,  o=o9,  s=s9);   /* 비전형   */
%buga(i=b10, o=o10, s=s10);  /* 파견     */
%buga(i=b11, o=o11, s=s11);  /* 용역     */
%buga(i=b12, o=o12, s=s12);  /* 특수형태 */
%buga(i=b13, o=o13, s=s13);  /* 가정내   */
%buga(i=b14, o=o14, s=s14);  /* 일일     */


/*──────────────────────────────────────────────────────────────*/
/* STEP 3. 결과 병합 — 근로자수                                 */
/*──────────────────────────────────────────────────────────────*/
data result_num;
    merge o2 o9 o10 o11 o12 o13 o14;
    by 조사연월 성별코드;

    format 연월 $char6.;   연월 = 조사연월;
    format 성별 $char6.;
    if      성별코드=1 then 성별='1남자';
    else if 성별코드=2 then 성별='2여자';
    else                    성별='0합계';

    s2=round(s2,0.1);   s9=round(s9,0.1);
    s10=round(s10,0.1); s11=round(s11,0.1);
    s12=round(s12,0.1); s13=round(s13,0.1); s14=round(s14,0.1);

    비정규직=s2; 비전형=s9; 파견=s10; 용역=s11;
    특수형태=s12; 가정내=s13; 일일=s14;

    drop s2 s9 s10 s11 s12 s13 s14 조사연월 성별코드;
run;


/*──────────────────────────────────────────────────────────────*/
/* STEP 4. 구성비 (비정규직 대비, %)                            */
/*──────────────────────────────────────────────────────────────*/
data result_pct;
    set result_num;
    if 비정규직 > 0 then do;
        비전형   = round(비전형   / 비정규직 * 100, 0.1);
        파견     = round(파견     / 비정규직 * 100, 0.1);
        용역     = round(용역     / 비정규직 * 100, 0.1);
        특수형태 = round(특수형태 / 비정규직 * 100, 0.1);
        가정내   = round(가정내   / 비정규직 * 100, 0.1);
        일일     = round(일일     / 비정규직 * 100, 0.1);
        비정규직 = 100.0;
    end;
run;


